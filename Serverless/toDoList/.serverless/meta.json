{
  "/Users/pavelcalin/Desktop/devOps-labs/Serverless/toDoList/serverless.yml": {
    "versionFramework": "4.38.1",
    "servicePath": "/Users/pavelcalin/Desktop/devOps-labs/Serverless/toDoList/serverless.yml",
    "serviceConfigFileName": "serverless.yml",
    "service": {
      "org": "orgpavca",
      "app": "todolist",
      "service": "toDoList",
      "stages": {
        "default": {
          "params": {
            "tableName": "users-table-staging"
          }
        }
      },
      "plugins": [
        "serverless-wsgi",
        "serverless-python-requirements"
      ],
      "custom": {
        "wsgi": {
          "app": "app.app"
        }
      },
      "provider": {
        "name": "aws",
        "runtime": "python3.12",
        "region": "eu-west-3",
        "iam": {
          "role": {
            "statements": [
              {
                "Effect": "Allow",
                "Action": [
                  "dynamodb:Query",
                  "dynamodb:Scan",
                  "dynamodb:GetItem",
                  "dynamodb:PutItem",
                  "dynamodb:UpdateItem",
                  "dynamodb:DeleteItem"
                ],
                "Resource": [
                  {
                    "Fn::GetAtt": [
                      "UsersTable",
                      "Arn"
                    ]
                  }
                ]
              },
              {
                "Effect": "Allow",
                "Action": [
                  "sqs:SendMessage"
                ],
                "Resource": [
                  {
                    "Fn::GetAtt": [
                      "MyQueue",
                      "Arn"
                    ]
                  }
                ]
              }
            ]
          }
        },
        "environment": {
          "USERS_TABLE": "users-table-staging"
        },
        "stage": "staging",
        "versionFunctions": true
      },
      "functions": {
        "api": {
          "handler": "wsgi_handler.handler",
          "events": [
            {
              "http": {
                "path": "/",
                "method": "ANY"
              }
            },
            {
              "http": {
                "path": "/{proxy+}",
                "method": "ANY"
              }
            }
          ],
          "name": "toDoList-staging-api"
        },
        "worker": {
          "handler": "worker.handler",
          "timeout": 20,
          "events": [
            {
              "sqs": {
                "arn": {
                  "Fn::GetAtt": [
                    "MyQueue",
                    "Arn"
                  ]
                },
                "batchSize": 10,
                "functionResponseType": "ReportBatchItemFailures"
              }
            }
          ],
          "name": "toDoList-staging-worker"
        }
      },
      "resources": {
        "Parameters": {
          "VpcCidr": {
            "Type": "String",
            "Default": "10.0.0.0/16"
          },
          "PrivateSubnetCidr": {
            "Type": "String",
            "Default": "10.0.1.0/24"
          },
          "PrivateSubnetCidrB": {
            "Type": "String",
            "Default": "10.0.2.0/24"
          }
        },
        "Resources": {
          "Vpc": {
            "Type": "AWS::EC2::VPC",
            "Properties": {
              "CidrBlock": {
                "Ref": "VpcCidr"
              },
              "EnableDnsSupport": "yes",
              "EnableDnsHostnames": "yes",
              "Tags": [
                {
                  "Key": "Name",
                  "Value": {
                    "Fn::Sub": "${AWS::StackName}-vpc"
                  }
                }
              ]
            }
          },
          "PrivateSubnet": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
              "VpcId": {
                "Ref": "Vpc"
              },
              "CidrBlock": {
                "Ref": "PrivateSubnetCidr"
              },
              "AvailabilityZone": "eu-west-3a",
              "MapPublicIpOnLaunch": false,
              "Tags": [
                {
                  "Key": "Name",
                  "Value": {
                    "Fn::Sub": "subnet-A"
                  }
                }
              ]
            }
          },
          "PrivateSubnetB": {
            "Type": "AWS::EC2::Subnet",
            "Properties": {
              "VpcId": {
                "Ref": "Vpc"
              },
              "CidrBlock": {
                "Ref": "PrivateSubnetCidrB"
              },
              "AvailabilityZone": "eu-west-3b",
              "MapPublicIpOnLaunch": false,
              "Tags": [
                {
                  "Key": "Name",
                  "Value": {
                    "Fn::Sub": "subnet-B"
                  }
                }
              ]
            }
          },
          "MyQueue": {
            "Type": "AWS::SQS::Queue",
            "Properties": {
              "QueueName": "todolist-queue-staging",
              "VisibilityTimeout": 30
            }
          },
          "UsersTable": {
            "Type": "AWS::DynamoDB::Table",
            "Properties": {
              "AttributeDefinitions": [
                {
                  "AttributeName": "userId",
                  "AttributeType": "S"
                }
              ],
              "KeySchema": [
                {
                  "AttributeName": "userId",
                  "KeyType": "HASH"
                }
              ],
              "ProvisionedThroughput": {
                "ReadCapacityUnits": 1,
                "WriteCapacityUnits": 1
              },
              "TableName": "users-table-staging"
            }
          }
        }
      }
    },
    "provider": {
      "name": "aws",
      "runtime": "python3.12",
      "region": "eu-west-3",
      "iam": {
        "role": {
          "statements": [
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:Query",
                "dynamodb:Scan",
                "dynamodb:GetItem",
                "dynamodb:PutItem",
                "dynamodb:UpdateItem",
                "dynamodb:DeleteItem"
              ],
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "UsersTable",
                    "Arn"
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "sqs:SendMessage"
              ],
              "Resource": [
                {
                  "Fn::GetAtt": [
                    "MyQueue",
                    "Arn"
                  ]
                }
              ]
            }
          ]
        }
      },
      "environment": {
        "USERS_TABLE": "users-table-staging"
      },
      "stage": "staging",
      "versionFunctions": true
    },
    "dashboard": {
      "isEnabledForService": true,
      "requiredAuthentication": false,
      "orgFeaturesInUse": {
        "providers": false,
        "monitoring": false
      },
      "orgObservabilityIntegrations": null,
      "serviceAppId": "DzRvj8qqKB4TT9qzrk",
      "serviceProvider": null,
      "instanceParameters": null
    },
    "serviceRawFile": "org: orgpavca\napp: todolist\nservice: toDoList\n\nstages:\n  default:\n    params:\n      tableName: \"users-table-${sls:stage}\"\n\nplugins:\n  - serverless-wsgi\n  - serverless-python-requirements\n\ncustom:\n  wsgi:\n    app: app.app\n\nprovider:\n  name: aws\n  runtime: python3.12\n  region: eu-west-3\n\n  iam:\n    role:\n      statements:\n        - Effect: Allow\n          Action:\n            - dynamodb:Query\n            - dynamodb:Scan\n            - dynamodb:GetItem\n            - dynamodb:PutItem\n            - dynamodb:UpdateItem\n            - dynamodb:DeleteItem\n          Resource:\n            - Fn::GetAtt: [UsersTable, Arn]\n        - Effect: Allow\n          Action:\n            - sqs:SendMessage\n          Resource:\n            - Fn::GetAtt: [MyQueue, Arn]\n  environment:\n    USERS_TABLE: ${param:tableName}\n\nfunctions:\n  api:\n    handler: wsgi_handler.handler\n    events:\n      - http:\n          path: /\n          method: ANY\n      - http:\n          path: /{proxy+}\n          method: ANY\n\n  worker:\n    handler: worker.handler\n    timeout: 20\n    events:\n      - sqs:\n          arn: !GetAtt MyQueue.Arn\n          batchSize: 10\n          functionResponseType: ReportBatchItemFailures\n\nresources:\n  Parameters:\n    VpcCidr:\n      Type: String\n      Default: 10.0.0.0/16\n    PrivateSubnetCidr:\n      Type: String\n      Default: 10.0.1.0/24\n    PrivateSubnetCidrB:\n      Type: String\n      Default: 10.0.2.0/24\n  Resources:\n    Vpc:\n      Type: AWS::EC2::VPC\n      Properties:\n        CidrBlock: !Ref VpcCidr\n        EnableDnsSupport: yes\n        EnableDnsHostnames: yes\n        Tags:\n          - Key: Name\n            Value: !Sub \"${AWS::StackName}-vpc\"\n\n    PrivateSubnet:\n      Type: AWS::EC2::Subnet\n      Properties:\n        VpcId: !Ref Vpc\n        CidrBlock: !Ref PrivateSubnetCidr\n        AvailabilityZone: eu-west-3a\n        MapPublicIpOnLaunch: false\n        Tags:\n          - Key: Name\n            Value: !Sub \"subnet-A\"\n\n    PrivateSubnetB:\n      Type: AWS::EC2::Subnet\n      Properties:\n        VpcId: !Ref Vpc\n        CidrBlock: !Ref PrivateSubnetCidrB\n        AvailabilityZone: eu-west-3b\n        MapPublicIpOnLaunch: false\n        Tags:\n          - Key: Name\n            Value: !Sub \"subnet-B\"\n\n    MyQueue:\n      Type: AWS::SQS::Queue\n      Properties:\n        QueueName: todolist-queue-${sls:stage}\n        VisibilityTimeout: 30\n\n\n    UsersTable:\n      Type: AWS::DynamoDB::Table\n      Properties:\n        AttributeDefinitions:\n          - AttributeName: userId\n            AttributeType: S\n        KeySchema:\n          - AttributeName: userId\n            KeyType: HASH\n        ProvisionedThroughput:\n          ReadCapacityUnits: 1\n          WriteCapacityUnits: 1\n        TableName: ${param:tableName}\n",
